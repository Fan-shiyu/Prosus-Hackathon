# Copy to .env and fill in. .env is git-ignored — NEVER commit real keys.

# RestBench game server
RESTBENCH_URL=http://52.48.183.209:8001

# LiteLLM proxy (OpenAI-compatible) for the L3 judgment layer
LITELLM_BASE_URL=http://litellm-production.eba-pvykax23.eu-west-1.elasticbeanstalk.com/
LITELLM_API_KEY=sk-REPLACE_ME

# Model for the sparing L3 LLM layer (proxy passthrough form: openai/<model>)
# Dev/cheap: openai/gpt-5-nano | openai/gpt-4.1-mini
# Eval/strong: openai/gpt-5.4 | openai/gpt-5
AGENT_MODEL=openai/gpt-4.1-mini

# Set to 1 to disable L3 entirely (pure-rules mode — zero token cost)
JFAM_LLM_OFF=0

# Team name on the leaderboard — keep constant
TEAM_NAME=JFAM_agents
